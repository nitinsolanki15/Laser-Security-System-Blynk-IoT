/************************************************************
      Laser Security System with ESP32 + Blynk IoT
************************************************************/

#define BLYNK_TEMPLATE_ID "..."
#define BLYNK_TEMPLATE_NAME "Laser Security"
#define BLYNK_AUTH_TOKEN "..."

#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>

char ssid[] = "YOUR_WIFI_NAME";
char pass[] = "WIFI_PASSWORD";

// ---------------- Pins ----------------
#define LDR_PIN      ..
#define BUZZER_PIN   ..
#define LED_PIN      ..

// ---------------- Variables ----------------
bool systemArmed = true;
bool notificationSent = false;
int alarmCount = 0;

// ------------------------------------------------
// Arm / Disarm Switch (V3)
// ------------------------------------------------
BLYNK_WRITE(V3)
{
  systemArmed = param.asInt();

  if(systemArmed)
  {
    Serial.println("System Armed");
    Blynk.virtualWrite(V0, "ARMED");
  }
  else
  {
    Serial.println("System Disarmed");

    digitalWrite(BUZZER_PIN, LOW);
    digitalWrite(LED_PIN, LOW);

    Blynk.virtualWrite(V0, "DISARMED");
    Blynk.virtualWrite(V1, 0);
  }
}

void setup()
{
  Serial.begin(115200);

  pinMode(LDR_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);

  digitalWrite(BUZZER_PIN, LOW);
  digitalWrite(LED_PIN, LOW);

  Serial.println("Connecting to WiFi & Blynk...");

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  Serial.println("Connected!");

  Blynk.virtualWrite(V4, alarmCount);
}

void loop()
{
  Blynk.run();

  // Read Digital Sensor (0 or 1)
  int sensor = digitalRead(LDR_PIN);

  // Show Sensor Value
  Blynk.virtualWrite(V2, sensor);

  Serial.print("LDR = ");
  Serial.println(sensor);

  // If System is OFF
  if(!systemArmed)
  {
    delay(100);
    return;
  }

  // ================= SAFE =================
  if(sensor == HIGH)
  {
    digitalWrite(BUZZER_PIN, LOW);
    digitalWrite(LED_PIN, LOW);

    Blynk.virtualWrite(V0, "SAFE");
    Blynk.virtualWrite(V1, 0);

    notificationSent = false;
  }

  // ================= INTRUDER =================
  else
  {
    digitalWrite(BUZZER_PIN, HIGH);
    digitalWrite(LED_PIN, HIGH);

    Blynk.virtualWrite(V0, "INTRUDER");
    Blynk.virtualWrite(V1, 255);

    if(!notificationSent)
    {
      alarmCount++;

      Blynk.virtualWrite(V4, alarmCount);

      Blynk.logEvent(
        "intruder",
        "🚨 Laser Security Alert!\nIntruder Detected!"
      );

      Serial.println("🚨 Intruder Detected!");

      notificationSent = true;
    }
  }

  delay(100);
}
